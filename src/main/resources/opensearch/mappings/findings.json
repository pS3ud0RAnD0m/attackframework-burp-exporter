            "type": "keyword",
            "ignore_above": 8191
          }
        }
      },
      {
        "response_header_values": {
          "path_match": "requests_responses.response.header.*",
          "match_mapping_type": "string",
          "mapping": {
            "type": "keyword",
            "ignore_above": 8191
